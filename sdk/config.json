{
    "qemu-exec": "qemu-system-x86_64",
    "qemuflags": [
        "-d int",
        "-m 4G",
        "-enable-kvm",
        "-no-reboot",
        "-no-shutdown",
        "-serial stdio"
    ],

    "cc": "clang",
    "cflags": [
        "-fno-stack-protector",
        "-ggdb",
        "-Wall",
        "-Wextra",
        "-Werror",
        "-std=gnu2x",
        "-Wvla",
        "-Ilib/headers",
        "-I.headers"
    ],

    "ld": "ld.lld",
    "ldflags": [],

    "as": "nasm",
    "asflags": [
        "-felf64",
        "-Fdwarf",
        "-g"
    ],

    "ar": "llvm-ar",
    "arflags": "rcs"
}