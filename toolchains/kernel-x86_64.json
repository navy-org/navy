{
    "id": "kernel-x86_64",
    "type": "toolchain",

    "cc": "clang",
    "cflags": [
        "-ffreestanding",
        "-target x86_64-elf-none",
        "-mno-80387",
        "-mno-mmx", 
        "-mno-3dnow",
        "-mno-red-zone",
        "-mcmodel=kernel",
        "-mno-sse", 
        "-mno-sse2",
        "-fno-stack-protector",
        "-fno-builtin",
        "-ggdb",
        "-Wall",
        "-Wextra",
        "-Werror",
        "-std=gnu2x",
        "-Wvla",
        "-I./src",
        "-I./src/libc",
        "-I.build/repos/",
        "-DARCH_X86_64"
    ],

    "as": "nasm",
    "asflags": [
        "-felf64",
        "-Fdwarf",
        "-g"
    ],

    "ld": "ld.lld",
    "ldflags": [
        "-T./src/kernel/linker.ld",
        "-z max-page-size=0x1000"
    ], 

    "ar": "llvm-ar",
    "arflags": "rcs",

    "run": [
        "qemu-system-x86_64",
        "-m", "4G",
        "-enable-kvm",
        "-no-reboot",
        "-no-shutdown",
        "-serial","stdio",
        "-smp", "4",
        "-bios", "./bios",
        "-drive", "file=fat:rw:$SYSROOT,media=disk,format=raw"
    ]
}