{
    "id": "x86_64 limine",
    "type": "profile",

    "toolchain": "kernel-x86_64",

    "run": [
        "qemu-system-x86_64",
        "-m", "4G",
        "-enable-kvm",
        "-no-reboot",
        "-no-shutdown",
        "-serial","stdio",
        "-smp", "4",
        "-bios", "./bios",
        "-drive", "file=fat:rw:$SYSROOT,media=disk,format=raw"
    ],

    "depends": [
        "kernel",
        "skift-loader",
        "x86_64"
    ],

    "install": [
        {
            "url": "https://retrage.github.io/edk2-nightly/bin/DEBUGX64_OVMF.fd",
            "dst-out": "/bios"
        }
    ]
}